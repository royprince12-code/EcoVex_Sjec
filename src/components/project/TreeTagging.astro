</Layout>

<style>
    *{
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    .main{
        background-color:#0a0f0a;
        min-height: 100vh;
        height: auto;
    }
    .project{
        padding: 200px 400px 50px  400px;
    }
    .projectname{
        font-size: 48px;
        color: #fff;
        margin-bottom: 20px;
    }
    .info{
        font-size: 18px;
        color: #a0ac9f;
        margin-bottom: 100px;
    }
    .img{
        width: 100%;
        height: 500px;
        background-color: #0a0f0a;
        margin-bottom: 50px;
        background-image: url("/spider.jpg");
        background-size: contain;
        background-repeat: no-repeat;
        background-position: center;
    }
    .q{
        font-size: 28px;
        color: #fff;
        margin-bottom: 20px;
    }
    .s{
        font-size: 18px;
        color: #a0ac9f;
        margin-bottom: 50px;
    }
    .contibutors{
        font-size: 28px;
        color: #fff;
        margin-bottom: 20px;
    }
    .border{
        width: 100%;
        border: 1px solid rgba(0, 150, 136, 0.2);
        margin-bottom: 30px;
    }
     .gradient{
        background: linear-gradient(135deg, #8bc34a, #009688);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    } 
    .contri{
        border: 1px solid rgba(0, 150, 136, 0.2);
        background-color: #0096880D;
        border-radius: 20px;
        padding: 20px 90px 20px 40px;
        width: fit-content;
        margin-bottom: 30px;
    }
    .name{
        text-align: start;
        font-size: 18px;
        color: #fff;
        margin-bottom: 10px;
    }
    .title{
        font-size: 14px;
        color: #fff;
        margin-left: 20px;
    }
    @media (max-width: 1500px) {
        .project {
            padding: 100px 20px 50px 20px;
        }
        .projectname {
            font-size: 32px;
        }
        .info { 
            font-size: 16px;
        }
        .q {
            font-size: 20px;
        }
        .s {
            font-size: 16px;
        }
        .contibutor {
            font-size: 20px;
        }
        .name {
            font-size: 16px;
        }
        .title {
            font-size: 14px;
        }
    }
</style>