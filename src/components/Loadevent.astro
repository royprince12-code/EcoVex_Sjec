---
import Layout from '../layouts/Layout.astro';
---
<Layout>
<div id ="main">
    <h1 id="head">Event <span class="gradient">TIMELINE</span></h1>
    <p id="para">Explore our journey through workshops, hackathons, and tech talks on campus.</p>
    <div id="project">
        <div class="container">
            <div class="img"></div>
            <h3 class="time">12-05-2023</h3>
            <h3 class="title">(; Project Clover</h3>
            <p class="content">Project Clover is our flagship initiative, focused on developing a cutting-edge electric vehicle that combines sustainability with high performance.</p> 
                <span class = "type">workshop</span>
                <span class = "incomplete">incomplete</span>
        </div>
        <div class="container">
            <div class="img"></div>
            <h3 class="time">12-05-2023</h3>
            <h3 class="title">(; Project Clover</h3>
            <p class="content">Project Clover is our flagship initiative, focused on developing a cutting-edge electric vehicle that combines sustainability with high performance.</p> 
                <span class = "type">workshop</span>
                <span class = "progress">complete</span>
        </div>
        <div class="container">
            <div class="img"></div>
            <h3 class="time">12-05-2023</h3>
            <h3 class="title">(; Project Clover</h3>
            <p class="content">Project Clover is our flagship initiative, focused on developing a cutting-edge electric vehicle that combines sustainability with high performance.</p> 
                <span class = "type">talk</span>
                <span class = "progress">complete</span>
        </div>
        </div>
        <div class="loading">
    <a href="/EcoVex_Sjec/event" class="load">View Event Highlights</a>
    </div>
</div>
</Layout>

<style>
*{
    margin:0;
    padding:0;
    box-sizing: border-box;
}
#main{
    min-height: 100vh;
    height: auto;
    background-color:#0a0f0a ;
}
.container{
        background-color: #0096880D;
        border: 1px solid rgba(0, 150, 136, 0.2);
        text-align: center;
        border-radius: 20px;
        margin: 20px;
        padding: 40px;
        justify-items: start;
        transition: translate ease;
}
#project{
     display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 20px;
    justify-content: center;
    margin-left: 150px;
    margin-right: 150px;
}
.img{
    background-color: #ffffff1a;
    border-radius: 50%;
    margin-bottom: 30px;
    width: 150px;
    height: 150px;
    margin-left: auto;
    margin-right: auto;
    background-image: url("/logo1.jpeg");
    background-size:130px;
    background-position: center;
    background-repeat: no-repeat;
    margin-top: 15px;
    border: 2px solid rgba(0, 150, 136, 0.2);
}
.time{
    color: #e0f2f1;
    font-size: 16px;
    margin-bottom: 20px;
    margin-left: auto;
    margin-right: auto;
}
.title{
    color: #e0f2f1;
    font-size: 24px;
    margin-bottom: 20px;
    padding-left: 30px;
}
.content{
    color: #a0ac9f;
    font-size: 16px;
    margin-bottom: 90px;
}
.container:hover{
    translate: 0 -10px;
     box-shadow: rgba(52, 211, 153, 0.3) 0px 10px 30px -10px;
    .img{
        translate: 0 -10px;
        box-shadow: rgba(52, 211, 153, 0.3) 0px 10px 30px -10px;
    }
}
.type{
        border: 1px solid #a0ac9f;
        background-color: #ffffff0D;
        color:#a0ac9f;
        border-radius: 15px;
        font-size: 12px;
        padding: 6px 20px;
        margin-right: 15px;
}

.progress{
        border: 1px solid #ffffff1a;
        background-color: #10FB981A;
        padding: 6px 20px;
        color:#e0f2f1;
        border-radius: 15px;
        font-size: 12px;
}
.incomplete{
        border: 1px solid #ffffff1a;
        background-color: #2D1A1A;
        color:#e0f2f1;
        border-radius: 15px;
        font-size: 12px;
        padding: 6px 20px;
}
#head{
        font-size: 48px;
        color: #e0f2f1;
        text-align: center;
        padding-top: 50px;
}
.gradient{
        background: linear-gradient(135deg, #4a7c44 0%, #34e9bd 100%);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
}
#para{
        color: #a0ac9f;
        font-size: 18px;
        text-align: center;
        margin-top: 10px;
        padding-bottom: 50px;
        padding-left: 30px;
        padding-right: 30px;
 }
.load{
    text-decoration: none;
    color: #e0f2f1;
    background-color: #ffffff0D;
    padding: 20px 40px 20px 40px;
    border-radius: 50px;
    border: 1.2px solid #34e9bd;
    font-weight: bold ;
    font-size: 16px;
    transition:color 0.2s ease;
}
.load:hover{
    background-color: #ffffff1a;
}
.loading{
    padding:60px 20px 60px 20px;
    margin-top: 40px;
    margin-left:42%;
    margin-right: 30%;
}
@media (max-width: 1200px)
{
    .loading{
        margin-left:36%;
        margin-right: 20%;
}
}
@media (max-width: 850px)
{
    .loading{
        margin-left:260px;
        margin-right: 0;
}
}
@media (max-width: 800px)
{
    .loading{
        margin-left:200px;
        margin-right: 0;
}
}
@media (max-width: 650px)
{
    .loading{
        margin-left:170px;
        margin-right: 0;
}
}
@media (max-width: 550px)
{
    .loading{
        margin-left:140px;
        margin-right: 0;
}
}
@media (max-width: 500px)
{
    .loading{
        margin-left:100px;
        margin-right: 0;
}
}
@media (max-width: 400px)
{
    .loading{
        margin-left:40px;
        margin-right: 0;
}
}
@media (max-width: 350px)
{
    .loading{
        margin-left:20px;
        margin-right: 0;
}
}
</style>