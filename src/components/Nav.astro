---
import Layout from "../layouts/Layout.astro"
---
<Layout>
<div id="main">
  <div id="Nav">
    <ul id="desk">
      <li><a href="/EcoVex_Sjec/"><span id="logo"></span></a></li>
      <li class="hideonmobile"><a href="/EcoVex_Sjec/">Home</a></li>
      <li class="hideonmobile"><a href="/EcoVex_Sjec/team">Team</a></li>
      <li class="hideonmobile"><a href="/EcoVex_Sjec/event">Events</a></li>
      <li class="hideonmobile">
        <a href="/EcoVex_Sjec/projects">Projects</a>
      </li>
      <li
        class="hidemenu"
        onclick="const sidebar = document.querySelector('.sidebar'); sidebar.style.display = 'flex'"
      >
        <a
          ><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" height="30px" fill="#a0ac9f"><!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M96 160C96 142.3 110.3 128 128 128L512 128C529.7 128 544 142.3 544 160C544 177.7 529.7 192 512 192L128 192C110.3 192 96 177.7 96 160zM96 320C96 302.3 110.3 288 128 288L512 288C529.7 288 544 302.3 544 320C544 337.7 529.7 352 512 352L128 352C110.3 352 96 337.7 96 320zM544 480C544 497.7 529.7 512 512 512L128 512C110.3 512 96 497.7 96 480C96 462.3 110.3 448 128 448L512 448C529.7 448 544 462.3 544 480z"/></svg></a>
      </li>
    </ul>
    <ul class="sidebar">
      <li>
        <a onclick="document.querySelector('.sidebar').style.display = 'none'"
          ><svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 384 512"
            height="24px"
            fill="#a0ac9f"
            ><path
              d="M55.1 73.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L147.2 256 9.9 393.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L192.5 301.3 329.9 438.6c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L237.8 256 375.1 118.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L192.5 210.7 55.1 73.4z"
            ></path></svg
          ></a
        >
      </li>
      <li><a href="/EcoVex_Sjec/">Home</a></li>
      <li><a href="/EcoVex_Sjec/team">Team</a></li>
      <li><a href="/EcoVex_Sjec/event">Events</a></li>
      <li><a href="/EcoVex_Sjec/projects">Projects</a></li>
    </ul>
  </div>
</div>
</Layout>

<script>
  const currentPath = window.location.pathname;

  document.querySelectorAll("#Nav a").forEach((link) => {
    const href = link.getAttribute("href");
    if (
      href &&
      href !== "/EcoVex_Sjec/" &&
      currentPath.includes(href.replace("/EcoVex_Sjec", ""))
    ) {
      link.classList.add("active");
    } else if (
      href === "/EcoVex_Sjec/" &&
      (currentPath === "/EcoVex_Sjec/" || currentPath === "/EcoVex_Sjec")
    ) {
      link.classList.add("active");
    }
  });
</script>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  #main {
    z-index: 999;
    position: fixed;
    left: 50%;
  }
  #Nav #desk {
    backdrop-filter: blur(20px);
    width: 150%;
    list-style: none;
    display: flex;
    justify-content: center;
    align-items: center;
    border: 1px solid rgba(0, 150, 136, 0.2);
    margin-top: 30px;
    border-radius: 20px;
    transform: translateX(-50%);
    margin-left: auto;
    margin-right: auto;
  }
  #Nav #desk li {
    height: 50px;
    margin-left: 10px;
  }
  #Nav #desk a {
    height: 100%;
    padding: 0 30px;
    text-decoration: none;
    font-size: 16px;
    display: flex;
    align-items: center;
    color: #a0ac9f;
  }
  #Nav #desk a:hover {
    color: #34e9bd;
  }
  #logo {
    height: 50px;
    width: 50px;
    background-image: url("/logo.png");
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
  }
  #Nav #desk li:first-child {
    margin-right: auto;
  }
  #Nav #desk a:active {
    text-decoration: underline solid #34e9bd;
  }
  .sidebar {
    list-style: none;
    position: fixed;
    top: 0;
    right: 0;
    height: 50vh;
    width: 50vw;
    z-index: 999;
    backdrop-filter: blur(20px);
    display: none;
    flex-direction: column;
    align-items: start;
    justify-content: flex-start;
  }

  .sidebar li {
    width: 100%;
    height: 50px;
  }
  .sidebar a {
    width: 100%;
    height: 100%;
    padding: 0 30px;
    text-decoration: none;
    font-size: 20px;
    display: flex;
    align-items: center;
    color: #a0ac9f;
    padding-top: 20px;
    padding-bottom: 20px;
  }
  .sidebar  li:first-child {
    margin-top: 20px;
    margin-left: 75%;
  }
  #Nav #desk a.active {
    color: #34e9bd;
    text-decoration: underline solid #34e9bd;
  }

  .sidebar a.active {
    color: #34e9bd;
  }
  .sidebar a:active {
    text-decoration: underline solid #34e9bd;
  }
  .sidebar a:hover {
    color: #34e9bd;
  }
  .hidemenu {
    display: none;
  }
  @media (max-width: 950px) {
    .hideonmobile {
      display: none;
    }
    .hidemenu {
      display: block;
    }
  }
  @media (max-width: 450px) {
    .sidebar {
      width: 100%;
    }
  }
</style>
